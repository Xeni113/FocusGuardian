# ============================================
# FocusGuardian - Git Ignore
# ============================================


# --------------------
# Python
# --------------------

__pycache__/
*.py[cod]
*$py.class


# --------------------
# Virtual environments
# --------------------

.venv/
venv/
env/
ENV/


# --------------------
# IDE / Editor
# --------------------

.vscode/
.idea/


# --------------------
# OS-generated files
# --------------------

.DS_Store
Thumbs.db
desktop.ini


# --------------------
# Python testing/cache
# --------------------

.pytest_cache/
.coverage
htmlcov/


# --------------------
# Runtime-generated data
# --------------------

data/*.json


# --------------------
# Logs
# --------------------

*.log
logs/


# --------------------
# Temporary files
# --------------------

*.tmp
*.temp